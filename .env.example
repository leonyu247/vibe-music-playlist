# Groq API Key (free tier: 14,400 requests/day)
# Get yours free at: https://console.groq.com
# NOTE: Some Groq keys are temporary — check console.groq.com for your key's expiry status
GROQ_API_KEY=your_groq_api_key_here

# Spotify App Credentials
# Create an app at: https://developer.spotify.com/dashboard
# Set the Redirect URI in your Spotify app to: http://localhost:8501
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8501
